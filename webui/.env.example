# Socratic Tutor Explorer — gateway credentials.
#
# Copy this file to  webui/.env  and fill in your key. webui/.env is gitignored, so real
# secrets never get committed. These are the SAME variables the eval harness uses — if your
# shell already exports them, you don't need this file at all (an exported shell always wins).
#
#   cp webui/.env.example webui/.env    # then edit the OPENAI_API_KEY line
#   python webui/run.py

# TrueFoundry gateway (OpenAI-compatible). Must NOT be api.openai.com, or the frontier
# tutor/judge calls 400 with "invalid model ID".
OPENAI_BASE_URL=https://gateway.truefoundry.ai

# Your gateway API key. Never commit the real value.
OPENAI_API_KEY=replace-with-your-gateway-key

# Frontier judge model id used across the compare suite.
OPENAI_JUDGE_MODEL=openai-group/gpt-5.5
