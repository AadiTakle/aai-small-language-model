.venv/
__pycache__/
*.pyc
.DS_Store

# Tooling caches (regenerated locally)
graphify-out/
.serena/

# Local Claude config (personal, machine-specific)
.claude/

# Trained adapter/model weights (regenerated by training; not version-controlled)
adapters/

# Cursor local config
.cursor/

# Downloaded third-party datasets (regenerated; attributed in docs)
data/external/

# Gap-loop working dir: keep only the human/structured trace; everything else is regenerable
eval/results/loop/*
!eval/results/loop/log.md
!eval/results/loop/history.json

# Manual-review apps + reconcile working files are regenerable; keep ONLY the provenance
# of the gold relabel (what changed + the full proposal with reasons).
eval/gold/review/*
!eval/gold/review/proposed_edits.json
!eval/gold/review/reconcile_applied.json
# pre-reconcile gold backup (git history already holds the prior version)
eval/gold/*.bak.jsonl

# generated human-review UIs (regenerable from scripts + flagged jsonl)
eval/gold/review/**/ruling.html
